---
// Komponent odbiera src i alt przekazane z Markdowna/MDX
const { src, alt } = Astro.props;
---

<img
  src={src}
  alt={alt}
  width="800"        
  height="450"       
  loading="lazy"      
  decoding="async"    
  class="w-full h-auto rounded-lg"
/>

<style>
  img {
    display: block;
    max-width: 100%;
    height: auto;     
    aspect-ratio: 16 / 9;
    background-color: #f3f4f6;
  }
</style>